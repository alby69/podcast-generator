# ── LLM Provider ──────────────────────────────────────────────
# Choose: gemini (default), openai, anthropic, ollama
LLM_PROVIDER=gemini

# Gemini (free tier available)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (uncomment if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-your_key_here
# OPENAI_MODEL=gpt-4o-mini

# Anthropic (uncomment if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-your_key_here
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Ollama local (uncomment if LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── TTS ───────────────────────────────────────────────────────
# Choose: edge (default, free), elevenlabs
TTS_PROVIDER=edge
TTS_VOICE=it-IT-GiuseppeNeural
# ELEVENLABS_API_KEY=your_key_here
# ELEVENLABS_VOICE=your_voice_id

# ── Newsletter Source ─────────────────────────────────────────
SOURCE_NAME=There's An AI For That
NEWSLETTER_URL=https://newsletter.theresanaiforthat.com
# ARCHIVE_URL=https://newsletter.theresanaiforthat.com/archive

# ── Scraping Selectors (default Beehiiv) ──────────────────────
# LOAD_MORE_SELECTOR=button:has-text('Load More'), a:has-text('Load More')
# LINK_PATTERN=/p/

# ── Processing ────────────────────────────────────────────────
MAX_EPISODE_MINUTES=60
OUTPUT_DIR=./output
# USE_WEB_SEARCH=false

# ── Web App Auth ─────────────────────────────────────────────
# Set a password to protect the web UI
# WEB_PASSWORD=mysecretpassword
# API token for REST API (leave empty to disable auth)
# API_TOKEN=my-api-token
# WEB_SECRET_KEY=change-me-in-production
# WEB_PORT=8000
# WEB_HOST=0.0.0.0
